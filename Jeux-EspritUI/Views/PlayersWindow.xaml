<!-- Jeux-esprit.UI/Views/PlayersWindow.xaml -->
<Window x:Class="JeuxDesprit.UI.Views.PlayersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDesprit.UI.Views"
        mc:Ignorable="d"
        Title="Jeux d'Esprit - Gestion des Joueurs" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#3498db" Padding="20,15">
            <TextBlock Text="GESTION DES JOUEURS" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Liste des joueurs -->
            <Border Grid.Column="0" Background="White" BorderBrush="#ddd" BorderThickness="1" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Joueurs" FontSize="18" FontWeight="SemiBold" Margin="10" HorizontalAlignment="Center"/>
                    
                    <ListBox x:Name="LstPlayers" Grid.Row="1" Margin="10" BorderThickness="0" SelectionChanged="LstPlayers_SelectionChanged"/>
                    
                    <Button x:Name="BtnAddPlayer" Grid.Row="2" Content="Ajouter un joueur" Margin="10" Height="35" Click="BtnAddPlayer_Click"/>
                </Grid>
            </Border>
            
            <!-- Détails du joueur -->
            <Border Grid.Column="1" Background="White" BorderBrush="#ddd" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Name="TxtPlayerTitle" Grid.Row="0" Text="Détails du joueur" FontSize="18" FontWeight="SemiBold" Margin="10" HorizontalAlignment="Center"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                        <StackPanel x:Name="PanelPlayerDetails">
                            <!-- Détails du joueur -->
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Nom:" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtPlayerName" Grid.Column="1" IsEnabled="False"/>
                            </Grid>
                            
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email:" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtPlayerEmail" Grid.Column="1" IsEnabled="False"/>
                            </Grid>
                            
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Avatar:" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtPlayerAvatar" Grid.Column="1" IsEnabled="False"/>
                            </Grid>
                            
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Type de joueur:" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtPlayerType" Grid.Column="1" IsEnabled="False"/>
                            </Grid>
                            
                            <!-- Statistiques spécifiques aux amateurs/professionnels -->
                            <Expander Header="Statistiques spécifiques" Margin="0,10" IsExpanded="True">
                                <StackPanel x:Name="PanelSpecificStats" Margin="10">
                                    <!-- Niveau d'expérience (Amateur) -->
                                    <Grid x:Name="GridAmateurStats" Margin="0,5" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Niveau:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="TxtAmateurLevel" Grid.Column="1" IsEnabled="False"/>
                                    </Grid>
                                    
                                    <!-- Classement et parties gagnées (Pro) -->
                                    <Grid x:Name="GridProStats" Margin="0,5" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Classement:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="TxtProRanking" Grid.Column="1" IsEnabled="False"/>
                                    </Grid>
                                    
                                    <Grid x:Name="GridProWins" Margin="0,5" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Parties gagnées:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="TxtProWins" Grid.Column="1" IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            
                            <!-- Historique des parties -->
                            <Expander Header="Historique des parties" Margin="0,10">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Fonctionnalité à venir dans une prochaine version." Foreground="Gray" FontStyle="Italic"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <Button x:Name="BtnEditPlayer" Content="Modifier" Width="100" Height="35" Margin="5" IsEnabled="False" Click="BtnEditPlayer_Click"/>
                        <Button x:Name="BtnSavePlayer" Content="Enregistrer" Width="100" Height="35" Margin="5" Visibility="Collapsed" Click="BtnSavePlayer_Click"/>
                        <Button x:Name="BtnCancelEdit" Content="Annuler" Width="100" Height="35" Margin="5" Visibility="Collapsed" Click="BtnCancelEdit_Click"/>
                        <Button x:Name="BtnDeletePlayer" Content="Supprimer" Width="100" Height="35" Margin="5" IsEnabled="False" Click="BtnDeletePlayer_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Pied de page -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,15">
            <Button x:Name="BtnRefresh" Content="Actualiser" Width="120" Height="35" Margin="5,0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnClose" Content="Fermer" Width="120" Height="35" Margin="5,0" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>