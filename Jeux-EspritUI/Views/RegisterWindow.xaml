<!-- Jeux-esprit.UI/Views/RegisterWindow.xaml -->
<Window x:Class="JeuxDespritUI.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDespritUI.Views"
        mc:Ignorable="d"
        Title="Création de compte" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" 
                   Text="Créer un nouveau compte" 
                   FontSize="22" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,20" 
                   HorizontalAlignment="Center"/>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0">
                <TextBlock Text="Nom:" FontSize="14" Margin="0,10,0,5"/>
                <TextBox x:Name="TxtNom" Height="35" FontSize="14" Padding="5"/>

                <TextBlock Text="Email:" FontSize="14" Margin="0,15,0,5"/>
                <TextBox x:Name="TxtEmail" Height="35" FontSize="14" Padding="5"/>

                <TextBlock Text="Mot de passe:" FontSize="14" Margin="0,15,0,5"/>
                <PasswordBox x:Name="TxtPassword" Height="35" FontSize="14" Padding="5"/>

                <TextBlock Text="Confirmer le mot de passe:" FontSize="14" Margin="0,15,0,5"/>
                <PasswordBox x:Name="TxtConfirmPassword" Height="35" FontSize="14" Padding="5"/>

                <TextBlock Text="Avatar (description ou chemin):" FontSize="14" Margin="0,15,0,5"/>
                <TextBox x:Name="TxtAvatar" Height="35" FontSize="14" Padding="5" Text="default_avatar.png"/>

                <TextBlock Text="Type de joueur:" FontSize="14" Margin="0,15,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <RadioButton x:Name="RadioAmateur" Content="Amateur" GroupName="UserType" Margin="0,0,20,0" IsChecked="True"/>
                    <RadioButton x:Name="RadioProfessionnel" Content="Professionnel" GroupName="UserType"/>
                </StackPanel>

                <TextBlock x:Name="TxtError" 
                           Foreground="Red" 
                           FontSize="12" 
                           TextWrapping="Wrap" 
                           Margin="0,15,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Boutons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="BtnCreate" 
                    Content="Créer le compte" 
                    Width="140" 
                    Height="35" 
                    FontSize="14" 
                    Margin="10,0" 
                    Background="#2ecc71" 
                    Foreground="White"
                    Click="BtnCreate_Click"/>
            
            <Button x:Name="BtnCancel" 
                    Content="Annuler" 
                    Width="120" 
                    Height="35" 
                    FontSize="14" 
                    Margin="10,0" 
                    Background="#e74c3c" 
                    Foreground="White"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>