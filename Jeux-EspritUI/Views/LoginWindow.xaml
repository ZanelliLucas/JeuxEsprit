<!-- Jeux-esprit.UI/Views/LoginWindow.xaml -->
<Window x:Class="JeuxDesprit.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDesprit.UI.Views"
        mc:Ignorable="d"
        Title="Jeux d'Esprit - Connexion" Height="450" Width="600" 
        WindowStartupLocation="CenterScreen"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#3498db" Padding="20,15">
            <TextBlock Text="JEUX D'ESPRIT" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Message de bienvenue -->
            <TextBlock Grid.Row="0" 
                      Text="Bienvenue dans l'application Jeux d'Esprit!" 
                      FontSize="18" 
                      Margin="0,0,0,30" 
                      HorizontalAlignment="Center"/>

            <!-- Options de connexion -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
                <Button x:Name="BtnLogin" Content="Se connecter" Height="45" FontSize="16" Margin="0,10" Background="#2ecc71" Foreground="White" Click="BtnLogin_Click"/>
                <Button x:Name="BtnRegister" Content="Créer un compte" Height="45" FontSize="16" Margin="0,10" Background="#e67e22" Foreground="White" Click="BtnRegister_Click"/>
                <Button x:Name="BtnExit" Content="Quitter l'application" Height="45" FontSize="16" Margin="0,10" Background="#e74c3c" Foreground="White" Click="BtnExit_Click"/>
            </StackPanel>
            
            <!-- Information de version -->
            <TextBlock Grid.Row="2" 
                       Text="Version 1.0 - © 2025 Jeux d'Esprit" 
                       FontSize="12" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Bottom" 
                       Margin="0,20,0,0"/>
        </Grid>
    </Grid>
</Window>