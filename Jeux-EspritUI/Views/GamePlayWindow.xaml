<!-- Jeux-esprit.UI/Views/GamePlayWindow.xaml -->
<Window x:Class="JeuxDesprit.UI.Views.GamePlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDesprit.UI.Views"
        mc:Ignorable="d"
        Title="Jeux d'Esprit - Partie en cours" Height="650" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#3498db" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtGameTitle" Grid.Column="0" Text="JEU" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtLevel" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock x:Name="TxtTimer" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info joueur -->
        <Border Grid.Row="1" Background="#ecf0f1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtPlayerInfo" Grid.Column="0" Text="Joueur: " FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtScore" Grid.Column="1" Text="Score: 0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Zone de jeu -->
        <TabControl Grid.Row="2" x:Name="GameTabControl" Margin="20">
            <!-- Onglet Plus ou Moins -->
            <TabItem Header="Plus ou Moins" x:Name="TabPlusMoins" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Devinez un nombre entre les bornes indiquées" 
                              FontSize="16" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,15"/>
                    
                    <Border Grid.Row="1" 
                           Background="#e8f4f8" 
                           BorderBrush="#bce0ee" 
                           BorderThickness="1" 
                           Padding="15" 
                           Margin="0,0,0,15" 
                           CornerRadius="5">
                        <TextBlock x:Name="TxtPlusMoinsRange" Text="Nombre entre 1 et 100" FontSize="14"/>
                    </Border>
                    
                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock Text="Votre proposition:" FontSize="14" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPlusMoinsGuess" Grid.Column="0" Height="35" FontSize="16" Padding="5" Margin="0,0,10,0"/>
                            <Button x:Name="BtnPlusMoinsSubmit" Grid.Column="1" Content="Proposer" Height="35" Width="100" Click="BtnPlusMoinsSubmit_Click"/>
                        </Grid>
                        
                        <TextBlock x:Name="TxtPlusMoinsHint" 
                                  Margin="0,15" 
                                  Padding="10" 
                                  FontSize="14" 
                                  TextAlignment="Center" 
                                  Background="#f9f9f9" 
                                  BorderBrush="#ddd" 
                                  BorderThickness="1" 
                                  Text="En attente de votre première proposition..." 
                                  TextWrapping="Wrap"/>
                        
                        <TextBlock x:Name="TxtPlusMoinsRemaining" 
                                  Text="Essais restants: 10" 
                                  FontSize="14" 
                                  FontWeight="SemiBold" 
                                  HorizontalAlignment="Center" 
                                  Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnPlusMoinsRestart" Content="Nouvelle partie" Width="120" Height="35" Margin="5,0" Click="BtnRestartGame_Click"/>
                        <Button x:Name="BtnPlusMoinsQuit" Content="Terminer" Width="120" Height="35" Margin="5,0" Click="BtnQuitGame_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Onglet Pendu -->
            <TabItem Header="Pendu" x:Name="TabPendu" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Devinez le mot lettre par lettre avant d'être pendu" 
                              FontSize="16" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,15"/>
                    
                    <Border Grid.Row="1" 
                           Background="#e8f4f8" 
                           BorderBrush="#bce0ee" 
                           BorderThickness="1" 
                           Padding="15" 
                           Margin="0,0,0,15" 
                           CornerRadius="5">
                        <TextBlock x:Name="TxtPenduWord" Text="_ _ _ _ _" FontSize="22" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    </Border>
                    
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Affichage du pendu -->
                        <Border Grid.Column="0" BorderBrush="#ddd" BorderThickness="1" Margin="0,0,15,0">
                            <Viewbox Stretch="Uniform" Margin="10">
                                <Canvas x:Name="CanvasPendu" Width="200" Height="250">
                                    <!-- Le dessin du pendu sera dessiné en code -->
                                </Canvas>
                            </Viewbox>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="Proposez une lettre:" FontSize="14" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtPenduGuess" Grid.Column="0" Height="35" FontSize="16" Padding="5" Margin="0,0,10,0" MaxLength="1"/>
                                <Button x:Name="BtnPenduSubmit" Grid.Column="1" Content="Proposer" Height="35" Width="100" Click="BtnPenduSubmit_Click"/>
                            </Grid>
                            
                            <TextBlock Text="Lettres déjà essayées:" FontSize="14" Margin="0,15,0,5"/>
                            <TextBlock x:Name="TxtPenduLetters" 
                                      Text="" 
                                      FontSize="14" 
                                      TextWrapping="Wrap"
                                      MinHeight="50"
                                      Padding="5"
                                      Background="#f9f9f9"
                                      BorderBrush="#ddd"
                                      BorderThickness="1"/>
                            
                            <TextBlock x:Name="TxtPenduRemaining" 
                                      Text="Essais restants: 10" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Margin="0,15,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnPenduRestart" Content="Nouvelle partie" Width="120" Height="35" Margin="5,0" Click="BtnRestartGame_Click"/>
                        <Button x:Name="BtnPenduQuit" Content="Terminer" Width="120" Height="35" Margin="5,0" Click="BtnQuitGame_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Onglet César -->
            <TabItem Header="César" x:Name="TabCesar" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Déchiffrez un message en utilisant le chiffrement de César" 
                              FontSize="16" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,15"/>
                    
                    <Border Grid.Row="1" 
                           Background="#e8f4f8" 
                           BorderBrush="#bce0ee" 
                           BorderThickness="1" 
                           Padding="15" 
                           Margin="0,0,0,15" 
                           CornerRadius="5">
                        <TextBlock x:Name="TxtCesarMessage" 
                                  Text="Message chiffré à déchiffrer..." 
                                  FontSize="16" 
                                  TextWrapping="Wrap" 
                                  TextAlignment="Center" 
                                  FontFamily="Consolas"/>
                    </Border>
                    
                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock Text="Quel décalage a été utilisé pour chiffrer ce message?" FontSize="14" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtCesarGuess" Grid.Column="0" Height="35" FontSize="16" Padding="5" Margin="0,0,10,0"/>
                            <Button x:Name="BtnCesarSubmit" Grid.Column="1" Content="Proposer" Height="35" Width="100" Click="BtnCesarSubmit_Click"/>
                        </Grid>
                        
                        <TextBlock x:Name="TxtCesarResult" 
                                  Margin="0,15" 
                                  Padding="10" 
                                  FontSize="14" 
                                  TextAlignment="Center" 
                                  Background="#f9f9f9" 
                                  BorderBrush="#ddd" 
                                  BorderThickness="1" 
                                  Text="En attente de votre proposition..." 
                                  TextWrapping="Wrap"/>
                        
                        <TextBlock x:Name="TxtCesarRemaining" 
                                  Text="Essais restants: 3" 
                                  FontSize="14" 
                                  FontWeight="SemiBold" 
                                  HorizontalAlignment="Center" 
                                  Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnCesarRestart" Content="Nouvelle partie" Width="120" Height="35" Margin="5,0" Click="BtnRestartGame_Click"/>
                        <Button x:Name="BtnCesarQuit" Content="Terminer" Width="120" Height="35" Margin="5,0" Click="BtnQuitGame_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Onglet Vigenère -->
            <TabItem Header="Vigenère" x:Name="TabVigenere" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="Déchiffrez un message en utilisant le chiffrement de Vigenère" 
                              FontSize="16" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,15"/>
                    
                    <Border Grid.Row="1" 
                           Background="#e8f4f8" 
                           BorderBrush="#bce0ee" 
                           BorderThickness="1" 
                           Padding="15" 
                           Margin="0,0,0,15" 
                           CornerRadius="5">
                        <TextBlock x:Name="TxtVigenereMessage" 
                                  Text="Message chiffré à déchiffrer..." 
                                  FontSize="16" 
                                  TextWrapping="Wrap" 
                                  TextAlignment="Center" 
                                  FontFamily="Consolas"/>
                    </Border>
                    
                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtVigenereHint" 
                                  Margin="0,0,0,15" 
                                  FontSize="14" 
                                  TextAlignment="Center" 
                                  Foreground="#e67e22" 
                                  Text="Indice: La clé contient 5 lettres."/>
                        
                        <TextBlock Text="Quelle clé a été utilisée pour chiffrer ce message? (en MAJUSCULES)" FontSize="14" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtVigenereGuess" Grid.Column="0" Height="35" FontSize="16" Padding="5" Margin="0,0,10,0"/>
                            <Button x:Name="BtnVigenereSubmit" Grid.Column="1" Content="Proposer" Height="35" Width="100" Click="BtnVigenereSubmit_Click"/>
                        </Grid>
                        
                        <TextBlock x:Name="TxtVigenereResult" 
                                  Margin="0,15" 
                                  Padding="10" 
                                  FontSize="14" 
                                  TextAlignment="Center" 
                                  Background="#f9f9f9" 
                                  BorderBrush="#ddd" 
                                  BorderThickness="1" 
                                  Text="En attente de votre proposition..." 
                                  TextWrapping="Wrap"/>
                        
                        <TextBlock x:Name="TxtVigenereRemaining" 
                                  Text="Essais restants: 5" 
                                  FontSize="14" 
                                  FontWeight="SemiBold" 
                                  HorizontalAlignment="Center" 
                                  Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnVigenereRestart" Content="Nouvelle partie" Width="120" Height="35" Margin="5,0" Click="BtnRestartGame_Click"/>
                        <Button x:Name="BtnVigenereQuit" Content="Terminer" Width="120" Height="35" Margin="5,0" Click="BtnQuitGame_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Pied de page avec résultats -->
        <Border Grid.Row="3" Background="#ecf0f1" Padding="10">
            <TextBlock x:Name="TxtGameStatus" 
                      Text="Partie en cours..." 
                      FontSize="14" 
                      HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>