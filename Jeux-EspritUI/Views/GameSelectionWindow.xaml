<!-- Jeux-esprit.UI/Views/GameSelectionWindow.xaml -->
<Window x:Class="JeuxDesprit.UI.Views.GameSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDesprit.UI.Views"
        mc:Ignorable="d"
        Title="Jeux d'Esprit - Jouer" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#3498db" Padding="20,15">
            <TextBlock Text="SÉLECTION DU JEU" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Instructions -->
            <TextBlock Grid.Row="0" 
                       Text="Sélectionnez un jeu et un niveau de difficulté" 
                       FontSize="18" 
                       Margin="0,0,0,20" 
                       HorizontalAlignment="Center"/>

            <!-- Liste des jeux -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Liste des jeux -->
                <Border Grid.Column="0" 
                        Background="White" 
                        BorderBrush="#ddd" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Titre -->
                        <TextBlock Grid.Row="0" 
                                  Text="Jeux disponibles" 
                                  FontSize="16" 
                                  FontWeight="SemiBold" 
                                  Margin="10" 
                                  HorizontalAlignment="Center"/>
                        
                        <!-- Liste de jeux -->
                        <ListBox x:Name="LstGames" 
                                Grid.Row="1" 
                                Margin="10" 
                                BorderThickness="0"
                                SelectionChanged="LstGames_SelectionChanged">
                            <ListBoxItem Content="Plus ou Moins" Tag="PlusMoins"/>
                            <ListBoxItem Content="Pendu" Tag="Pendu"/>
                            <ListBoxItem Content="Chiffrement de César" Tag="Cesar"/>
                            <ListBoxItem Content="Chiffrement de Vigenère" Tag="Vigenere"/>
                        </ListBox>
                    </Grid>
                </Border>
                
                <!-- Détails du jeu -->
                <Border Grid.Column="1" 
                        Background="White" 
                        BorderBrush="#ddd" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Margin="10,0,0,0">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Titre du jeu sélectionné -->
                        <TextBlock x:Name="TxtGameTitle" 
                                  Grid.Row="0" 
                                  Text="Sélectionnez un jeu" 
                                  FontSize="18" 
                                  FontWeight="SemiBold" 
                                  Margin="0,0,0,10" 
                                  HorizontalAlignment="Center"/>
                        
                        <!-- Description du jeu -->
                        <TextBlock x:Name="TxtGameDescription" 
                                  Grid.Row="1" 
                                  Text="Cliquez sur un jeu pour voir sa description." 
                                  Margin="0,0,0,15" 
                                  TextWrapping="Wrap"/>
                        
                        <!-- Niveau de difficulté -->
                        <GroupBox Grid.Row="2" Header="Niveau de difficulté" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <RadioButton x:Name="RadioEasy" Content="Facile" GroupName="Level" IsChecked="True" Margin="0,5"/>
                                <RadioButton x:Name="RadioMedium" Content="Moyen" GroupName="Level" Margin="0,5"/>
                                <RadioButton x:Name="RadioHard" Content="Difficile" GroupName="Level" Margin="0,5"/>
                                <RadioButton x:Name="RadioExpert" Content="Expert" GroupName="Level" Margin="0,5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- Bouton jouer -->
                        <Button x:Name="BtnStartGame" 
                                Grid.Row="3" 
                                Content="Jouer" 
                                Height="40" 
                                FontSize="16" 
                                Margin="10" 
                                Background="#2ecc71" 
                                Foreground="White"
                                IsEnabled="False"
                                Click="BtnStartGame_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bouton retour -->
            <Button Grid.Row="2" 
                    Content="Retour au menu principal" 
                    HorizontalAlignment="Center" 
                    Padding="15,8" 
                    Margin="0,20,0,0" 
                    Background="#95a5a6" 
                    Foreground="White"
                    Click="BtnBack_Click"/>
        </Grid>
    </Grid>
</Window>