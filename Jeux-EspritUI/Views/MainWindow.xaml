<!-- Jeux-esprit.UI/Views/MainWindow.xaml -->
<Window x:Class="JeuxDespritUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JeuxDespritUI.Views"
        mc:Ignorable="d"
        Title="Jeux d'Esprit - Menu Principal" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#3498db" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="JEUX D'ESPRIT" Grid.Column="0" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtUserName" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="BtnLogout" Content="Déconnexion" Padding="10,5" Background="#e74c3c" Foreground="White" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sous-titre -->
        <TextBlock Grid.Row="1" 
                   Text="Menu Principal" 
                   FontSize="22" 
                   FontWeight="SemiBold" 
                   Margin="20,15" 
                   HorizontalAlignment="Center"/>

        <!-- Menu principal -->
        <Grid Grid.Row="2" Margin="40,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Boutons menu -->
            <Button x:Name="BtnPlay" 
                    Grid.Column="0" Grid.Row="0"
                    Content="Jouer" 
                    Margin="20" 
                    FontSize="22" 
                    Background="#2ecc71" 
                    Foreground="White" 
                    Click="BtnPlay_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button x:Name="BtnPlayers" 
                    Grid.Column="1" Grid.Row="0"
                    Content="Joueurs" 
                    Margin="20" 
                    FontSize="22" 
                    Background="#9b59b6" 
                    Foreground="White" 
                    Click="BtnPlayers_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button x:Name="BtnHistory" 
                    Grid.Column="0" Grid.Row="1"
                    Content="Historique" 
                    Margin="20" 
                    FontSize="22" 
                    Background="#e67e22" 
                    Foreground="White" 
                    Click="BtnHistory_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button x:Name="BtnGameTypes" 
                    Grid.Column="1" Grid.Row="1"
                    Content="Types de jeu" 
                    Margin="20" 
                    FontSize="22" 
                    Background="#3498db" 
                    Foreground="White" 
                    Click="BtnGameTypes_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Pied de page -->
        <Border Grid.Row="3" Background="#ecf0f1" Padding="10">
            <TextBlock Text="© 2025 Jeux d'Esprit - Version 1.0" 
                       FontSize="12" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>